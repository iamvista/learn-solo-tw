# ===========================================
# 必要環境變數（應用程式啟動必需）
# ===========================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ray_realms_course"


# --- Cloudflare Stream（影片上傳/播放）---
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_STREAM_CUSTOMER_CODE=""
CLOUDFLARE_STREAM_SIGNING_SECRET=""

# --- Cloudflare R2（圖片/檔案儲存）---
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME=""
CLOUDFLARE_R2_PUBLIC_URL=""

# --- Email（Resend 寄信服務）---
RESEND_API_KEY=""
EMAIL_FROM="noreply@example.com"

# --- App 設定（有 fallback 預設值，可不設）---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth.js
# 產生方式: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"
# 網站完整 URL（用於 OAuth 回呼）
AUTH_URL="http://localhost:3000"

# ===========================================
# 以下為可選環境變數，可以根據情況評估是否需要該功能
# ===========================================

# --- Google OAuth（Google 登入）---
# 在 Google Cloud Console 建立 OAuth 2.0 憑證
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --- Apple OAuth（Apple 登入）---
# AUTH_APPLE_ID=""
# AUTH_APPLE_TEAM_ID=""
# AUTH_APPLE_KEY_ID=""
# AUTH_APPLE_PRIVATE_KEY=""